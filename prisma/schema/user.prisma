model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  password     String
  role         Role
  status       UserStatus @default(ACTIVE)
  
  profile  Profile?

  gearItems GearItem[]
  rentalOrders RentalOrder[]
  reviews       Review[]
  payments      Payment[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("users")
}

enum Role {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}
