model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  password     String
  role         Role
  status       UserStatus @default(ACTIVE)
  phone        String?
  address      String?
  profileImage String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("users")
}

enum Role {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}
